<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>QuoteFlow Popup</title>

<style>

/* Floating Button */
.floating-btn {
  position: fixed;
  bottom: 25px;
  right: 25px;
  background: #ff4d00;
  color: white;
  padding: 14px 18px;
  border-radius: 50px;
  border: none;
  cursor: pointer;
  font-size: 14px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.3);
  z-index: 999;
}

/* Popup */
.popup {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

/* Box */
.popup-box {
  background: white;
  padding: 20px;
  width: 380px;
  max-width: 90%;
  border-radius: 12px;
  position: relative;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

/* Close */
.close {
  position: absolute;
  right: 12px;
  top: 8px;
  font-size: 22px;
  cursor: pointer;
}

/* Inputs */
input, select, textarea {
  width: 100%;
  margin: 8px 0;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  outline: none;
}

/* Submit */
button.submit {
  width: 100%;
  padding: 12px;
  background: green;
  color: white;
  border: none;
  cursor: pointer;
  border-radius: 6px;
}

/* Service buttons demo */
.service-btn {
  margin: 6px;
  padding: 10px 14px;
  background: #007bff;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

</style>
</head>

<body>

<!-- SERVICES (DEMO BUTTONS) -->
<div style="padding:30px;">
  <h2>Our Services</h2>

  <button class="service-btn" onclick="openForm('Repair & Maintenance')">Repair & Maintenance</button>
  <button class="service-btn" onclick="openForm('Painting Services')">Painting Services</button>
  <button class="service-btn" onclick="openForm('Electrical & Plumbing')">Electrical & Plumbing</button>
  <button class="service-btn" onclick="openForm('AC Maintenance & Repair')">AC Maintenance</button>
  <button class="service-btn" onclick="openForm('Cleaning Services')">Cleaning Services</button>
</div>

<!-- FLOATING BUTTON -->
<button class="floating-btn" onclick="openForm()">💬 Get Quote</button>

<!-- POPUP -->
<div class="popup" id="popup">
  <div class="popup-box">

    <span class="close" onclick="closeForm()">&times;</span>

    <h3>Request a Quotation</h3>

    <form action="https://api.web3forms.com/submit" method="POST">

      <!-- Web3Forms KEY -->
      <input type="hidden" name="access_key" value="e5995f02-b81e-4e1b-904e-bc5c5c5e3162">

      <input type="text" name="name" placeholder="Your Name" required>
      <input type="tel" name="phone" placeholder="Phone Number" required>
      <input type="email" name="email" placeholder="Email Address" required>

      <!-- ALL SERVICES -->
      <select name="service" id="serviceSelect" required>
        <option value="">Select Service</option>

        <option value="Repair & Maintenance">Repair & Maintenance</option>

        <option value="Home, Office & Villa Renovation">Home, Office & Villa Renovation</option>

        <option value="Painting Services">Painting Services</option>

        <option value="Electrical & Plumbing">Electrical & Plumbing</option>

        <option value="Home Appliance Installation & Maintenance">Home Appliance Installation & Maintenance</option>

        <option value="Carpentry Services">Carpentry Services</option>

        <option value="Bathroom Renovation">Bathroom Renovation</option>

        <option value="Kitchen Renovation">Kitchen Renovation</option>

        <option value="Cleaning Services">Cleaning Services</option>

        <option value="AC Maintenance & Repair">AC Maintenance & Repair</option>

        <option value="Pest & Bird Control">Pest & Bird Control</option>

        <option value="Packers & Movers">Packers & Movers</option>

        <option value="Professional Waterproofing Services">Professional Waterproofing Services</option>

      </select>

      <textarea name="message" placeholder="Your Message"></textarea>

      <button type="submit" class="submit">Send Request</button>
    </form>

  </div>
</div>

<script>

// OPEN POPUP
function openForm(service = "") {
  const popup = document.getElementById("popup");
  popup.style.display = "flex";

  if (service) {
    document.getElementById("serviceSelect").value = service;
  }
}

// CLOSE POPUP
function closeForm() {
  document.getElementById("popup").style.display = "none";
}

// AUTO POPUP AFTER LOAD
window.addEventListener("load", function () {
  setTimeout(function () {
    document.getElementById("popup").style.display = "flex";
  }, 2000);
});

// CLICK OUTSIDE TO CLOSE
window.addEventListener("click", function (e) {
  const popup = document.getElementById("popup");
  if (e.target === popup) {
    popup.style.display = "none";
  }
});

</script>

</body>
</html>
